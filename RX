#include <EEPROM.h>

int kp = 0, ki = 0, kd = 0;
const int EEPROM_ADDR[3] = {0, 4, 8};

void setup() {
  Serial.begin(9600); // HC-12 connected to Serial (pins 0/1)
  loadPIDValuesFromEEPROM();
  printPID();
}

void loop() {
  static String inputString = "";
  while (Serial.available()) {
    char inChar = (char)Serial.read();
    if (inChar == '\n') {
      inputString.trim(); // Remove whitespace
      processCommand(inputString);
      inputString = "";
    } else {
      inputString += inChar;
    }
  }
}

void processCommand(String cmd) {
  if (cmd.startsWith("KP,")) {
    kp = cmd.substring(3).toInt();
    Serial.print("Kp updated: "); Serial.println(kp);
    printPID();
  } else if (cmd.startsWith("KI,")) {
    ki = cmd.substring(3).toInt();
    Serial.print("Ki updated: "); Serial.println(ki);
    printPID();
  } else if (cmd.startsWith("KD,")) {
    kd = cmd.substring(3).toInt();
    Serial.print("Kd updated: "); Serial.println(kd);
    printPID();
  } else if (cmd.equals("SAVE")) {
    savePIDValuesToEEPROM();
    Serial.println("PID values saved to EEPROM.");
  } else if (cmd.equals("RESET")) {
    kp = 0; ki = 0; kd = 0;
    Serial.println("PID values reset to 0.");
    printPID();
    // Optionally, save zeros to EEPROM:
    // savePIDValuesToEEPROM();
  }
}

void savePIDValuesToEEPROM() {
  EEPROM.put(EEPROM_ADDR[0], kp);
  EEPROM.put(EEPROM_ADDR[1], ki);
  EEPROM.put(EEPROM_ADDR[2], kd);
}

void loadPIDValuesFromEEPROM() {
  EEPROM.get(EEPROM_ADDR[0], kp);
  EEPROM.get(EEPROM_ADDR[1], ki);
  EEPROM.get(EEPROM_ADDR[2], kd);
}

void printPID() {
  Serial.print("Kp: "); Serial.print(kp);
  Serial.print(" | Ki: "); Serial.print(ki);
  Serial.print(" | Kd: "); Serial.println(kd);
}
